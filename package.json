{
  "name": "astrohacking-visualizador",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "dotenv -e .env -e .env.local -- node scripts/run-prisma.mjs migrate deploy && dotenv -e .env -e .env.local -- node scripts/run-prisma.mjs generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "dotenv -e .env -e .env.local -- node scripts/run-prisma.mjs generate",
    "db:generate": "dotenv -e .env -e .env.local -- node scripts/run-prisma.mjs generate",
    "db:migrate": "dotenv -e .env -e .env.local -- node scripts/run-prisma.mjs migrate dev",
    "db:deploy": "dotenv -e .env -e .env.local -- node scripts/run-prisma.mjs migrate deploy",
    "db:push": "dotenv -e .env -e .env.local -- node scripts/run-prisma.mjs db push",
    "db:studio": "dotenv -e .env -e .env.local -- node scripts/run-prisma.mjs studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@prisma/client": "^6.19.3",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^4"
  }
}
